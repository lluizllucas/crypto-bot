####################################################
##################### ENV ##########################
####################################################

# development | production
ENV=production

####################################################
##################### AWS ##########################
####################################################

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

####################################################
#################### POSTGRES ######################
####################################################

# Em development: aponta para o Postgres local (docker-compose)
# Em production: aponta para o Supabase (Session Pooler, porta 5432)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cryptobot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=123456

####################################################
#################### BINANCE #######################
####################################################

BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_SECRET_KEY=

BINANCE_API_KEY=
BINANCE_SECRET_KEY=

####################################################
#################### DISCORD #######################
####################################################

DISCORD_WEBHOOK_URL=
